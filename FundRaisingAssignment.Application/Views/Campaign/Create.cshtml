@model FundRaisingAssignment.Application.Models.Campaign
@{
    ViewData["Title"] = "Create Campaign";
}

<div class="container mt-5 max-w-lg mx-auto" style="max-width: 800px;">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-primary text-white p-4 rounded-top-4">
            <h2 class="mb-0">Start a New Campaign</h2>
            <p class="text-white-50 mb-0">Fill in the details below to start fundraising.</p>
        </div>
        <div class="card-body p-4 p-md-5">
            <form asp-action="Create" method="post">
                <div class="mb-4">
                    <label asp-for="Title" class="form-label fw-bold">Campaign Title</label>
                    <input asp-for="Title" class="form-control form-control-lg bg-light" placeholder="e.g. Help Save the Local Park" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                
                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold">Description</label>
                    <textarea asp-for="Description" class="form-control form-control-lg bg-light" rows="5" placeholder="Tell your story..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                
                <div class="mb-4">
                    <label asp-for="TargetAmount" class="form-label fw-bold">Target Amount ($)</label>
                    <input asp-for="TargetAmount" type="number" step="0.01" class="form-control form-control-lg bg-light" placeholder="e.g. 5000" />
                    <span asp-validation-for="TargetAmount" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg fw-bold py-3">Publish Campaign</button>
                    <a asp-action="Index" class="btn btn-light btn-lg">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
