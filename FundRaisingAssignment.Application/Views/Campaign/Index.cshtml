@{
    ViewData["Title"] = "Manage Campaigns";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Your Campaigns</h1>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            + Create New Campaign
        </a>
    </div>

    <div class="alert alert-info border-0 shadow-sm rounded-3">
        <strong><i class="bi bi-info-circle"></i> Note:</strong> Only members who have been active for at least 3 days can access this page. You made it!
    </div>

    <div class="row mt-4">
        <div class="col-md-12 text-center text-muted py-5">
            <div class="display-1 text-light mb-3">📁</div>
            <h3>No campaigns found</h3>
            <p>You haven't created any campaigns yet. Start fundraising today!</p>
        </div>
    </div>
</div>
