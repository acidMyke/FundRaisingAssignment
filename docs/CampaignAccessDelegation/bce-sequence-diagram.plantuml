@startuml Campaign Delegate Flows
skinparam actorStyle awesome

actor User as Client
participant "CampaignManageDelegateController" as Controller
participant "CampaignDelegateService" as Service
participant "IAuthorizationService" as Auth
participant "CampaignRepository" as CampaignRepo
participant "CampaignDelegateRepository" as DelegateRepo
participant "UserRepository" as UserRepo

== Get Current Delegates (GET) ==
Client -> Controller: GetCurrentDelegatesAsync(campaignId)
activate Controller
Controller -> Service: GetDelegatesAsync(campaignId)
activate Service

Service -> Auth: AuthorizeAsync(user, resource, "CampaignOwner")
activate Auth
alt Unauthorized
    Auth --> Service: Forbidden
    deactivate Auth
    Service --> Controller: Lacks permission
    Controller --> Client: View("AccessDenied")
else Authorized
    activate Auth
    Auth --> Service: Authorized
    deactivate Auth
    Service -> DelegateRepo: GetDelegatesAsync(campaignId)
    activate DelegateRepo
    DelegateRepo --> Service: List<CampaignDelegatePermission>
    deactivate DelegateRepo
    Service --> Controller: List<CampaignDelegatePermission>
    deactivate Service
    Controller --> Client: View("DelegatesList", List)
    deactivate Controller
end

== Add New Member (POST) ==
Client -> Controller: AddNewMemberAsync(campaignId, email, permission)
activate Controller
Controller -> Service: AddDelegateAsync(campaignId, email, permission)
activate Service

Service -> Auth: AuthorizeAsync(user, resource, "CampaignOwner")
activate Auth
alt Unauthorized
    Auth --> Service: Forbidden
    deactivate Auth
    Service --> Controller: Lacks permission
    Controller --> Client: View("AccessDenied")
else Authorized
    activate Auth
    Auth --> Service: Authorized
    deactivate Auth
    Service -> UserRepo: GetUserByEmailAsync(email)
    activate UserRepo
    alt User Not Found
        UserRepo --> Service: null
        deactivate UserRepo
        Service --> Controller: User not found
        Controller -> Controller: Add Model Error
        Controller --> Client: View("AddMember", dtoWithError)
    else User Found
        activate UserRepo
        UserRepo --> Service: User
        deactivate UserRepo
        Service -> DelegateRepo: AddDelegatePermissionAsync(campaignId, userId, permission)
        activate DelegateRepo
        DelegateRepo --> Service: Success
        deactivate DelegateRepo
        Service --> Controller: Success
        deactivate Service
        Controller --> Client: RedirectToAction("GetCurrentDelegates")
        deactivate Controller
    end
end

== Update Permission (POST) ==
Client -> Controller: UpdatePermissionAsync(dto)
activate Controller
Controller -> Service: UpdateDelegatePermissionAsync(dto)
activate Service

Service -> Auth: AuthorizeAsync(user, resource, "CampaignOwner")
activate Auth
alt Unauthorized
    Auth --> Service: Forbidden
    deactivate Auth
    Service --> Controller: Lacks permission
    Controller --> Client: View("AccessDenied")
else Authorized
    activate Auth
    Auth --> Service: Authorized
    deactivate Auth
    
    Service -> DelegateRepo: RemoveDelegatePermissionAsync(...)
    activate DelegateRepo
    DelegateRepo --> Service: Removed
    deactivate DelegateRepo
    
    Service -> DelegateRepo: AddDelegatePermissionAsync(...)
    activate DelegateRepo
    DelegateRepo --> Service: Added
    deactivate DelegateRepo
    
    Service --> Controller: Success
    deactivate Service
    Controller --> Client: RedirectToAction("GetCurrentDelegates")
    deactivate Controller
end

@enduml